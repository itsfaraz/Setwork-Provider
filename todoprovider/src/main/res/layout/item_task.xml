<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/taskItem"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="6dp">

    <!-- Optional: Status dot / icon -->
    <ImageView
        android:id="@+id/taskStatusDot"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/bg_status_dot"
        android:layout_marginEnd="10dp"/>

    <!-- Text container (flexible) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Task title -->
        <TextView
            android:id="@+id/taskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Learning Meet with Michael Payne"
            android:textSize="14sp"
            android:textStyle="normal"
            android:textColor="@android:color/black"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Optional subtitle (time / category) -->
        <TextView
            android:id="@+id/taskDescription"
            android:layout_width="match_parent"
            android:layout_marginVertical="4dp"
            android:layout_height="wrap_content"
            android:text="Informed learning meet with michael payne and julie robert regarding data science and practices"
            android:textSize="11sp"
            android:maxLines="3"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:visibility="visible"/>

    </LinearLayout>


    <TextView
        android:id="@+id/taskTime"
        android:layout_marginHorizontal="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5:00 PM"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginTop="2dp"
        android:visibility="visible"/>

</LinearLayout>